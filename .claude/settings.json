{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "claude-haiku-4-5-20251001",
  "modelOverride": "haiku",
  "fastMode": false,
  "verbose": true,
  "autoCompactEnabled": true,
  "autoCompactWindow": 150000,
  "fileCheckpointingEnabled": true,
  "respectGitignore": true,
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(git *)",
      "Bash(uv *)",
      "Bash(pytest *)",
      "Bash(black *)",
      "Bash(ruff *)",
      "Bash(python *)",
      "Bash(ls *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(cat *)",
      "Bash(tail *)",
      "Bash(head *)",
      "Bash(pwd *)",
      "Bash(echo *)",
      "Bash(which *)",
      "Bash(pip *)",
      "Bash(poetry *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(drop *)",
      "Bash(truncate *)",
      "Read(.env*)",
      "Write(.env*)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(git push *)",
      "Bash(git rebase *)",
      "Write(.github/*)",
      "Write(.env*)",
      "Bash(npm *)",
      "Bash(yarn *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-quality.sh",
            "statusMessage": "Running quality checks on edited file...",
            "timeout": 60
          }
        ]
      }
    ]
  },
  "alwaysThinkingEnabled": true,
  "enabledPlugins": {
    "example-skills@anthropic-agent-skills": true,
    "pyright-lsp@claude-plugins-official": true
  },
  "sandbox": {
    "enabled": false,
    "network": {
      "allowedDomains": [
        "*.anthropic.com",
        "api.anthropic.com",
        "github.com",
        "*.github.com",
        "pypi.org",
        "*.pypi.org"
      ]
    }
  },
  "attribution": {
    "commit": "Co-Authored-By: Claude <claude@anthropic.com>"
  },
  "spinnerTipsEnabled": true,
  "showTurnDuration": false,
  "showMessageTimestamps": false,
  "todo": false,
  "mcpServers": {
      "playwright": {
      "type": "local",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ],
      "env": {
        "NODE_ENV": "production"
      }
    }
  }
}
