{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "claude-haiku-4-5-20251001",
  "modelOverride": "haiku",
  "fastMode": false,
  "verbose": true,
  "autoCompactEnabled": true,
  "autoCompactWindow": 150000,
  "fileCheckpointingEnabled": true,
  "respectGitignore": true,
  "claudeMdExcludes": [
    "**/vendor/**/CLAUDE.md",
    "**/node_modules/**/CLAUDE.md"
  ],
  "agentRoles": {
    "architect": {
      "model": "claude-opus-4-8",
      "permissions": ["read", "view", "write:tasks.md", "write:docs/dev-note/*"],
      "maxSteps": 15,
      "forbidden": ["write:src/**", "write:tests/**", "bash:execute", "git:push"]
    },
    "coder": {
      "model": "claude-opus-4-8",
      "permissions": ["read", "write:src/**", "write:tests/**", "bash:compile", "bash:test"],
      "maxSteps": 20,
      "forbidden": ["write:CLAUDE.md", "write:AGENTS.md", "write:.claude/settings.json", "git:push:force"]
    },
    "reviewer": {
      "model": "claude-sonnet-5",
      "permissions": ["read", "bash:test", "bash:lint", "write:.test.*"],
      "maxSteps": 10,
      "forbidden": ["write:src/**", "git:merge", "git:push:force"]
    }
  },
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(git *)",
      "Bash(uv *)",
      "Bash(pytest *)",
      "Bash(black *)",
      "Bash(ruff *)",
      "Bash(python *)",
      "Bash(ls *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(cat *)",
      "Bash(tail *)",
      "Bash(head *)",
      "Bash(pwd *)",
      "Bash(echo *)",
      "Bash(which *)",
      "Bash(pip *)",
      "Bash(poetry *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(drop *)",
      "Bash(truncate *)",
      "Read(.env*)",
      "Write(.env*)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(git push *)",
      "Bash(git rebase *)",
      "Write(.github/*)",
      "Write(.env*)",
      "Bash(npm *)",
      "Bash(yarn *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-quality.sh",
            "statusMessage": "Running quality checks on edited file...",
            "timeout": 60
          }
        ]
      }
    ]
  },
  "alwaysThinkingEnabled": true,
  "enabledPlugins": {
    "example-skills@anthropic-agent-skills": true,
    "pyright-lsp@claude-plugins-official": true
  },
  "sandbox": {
    "enabled": false,
    "network": {
      "allowedDomains": [
        "*.anthropic.com",
        "api.anthropic.com",
        "github.com",
        "*.github.com",
        "pypi.org",
        "*.pypi.org"
      ]
    }
  },
  "attribution": {
    "commit": "Co-Authored-By: Claude <claude@anthropic.com>"
  },
  "spinnerTipsEnabled": true,
  "showTurnDuration": false,
  "showMessageTimestamps": false,
  "todo": false,
  "mcpServers": {
      "playwright": {
      "type": "local",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ],
      "env": {
        "NODE_ENV": "production"
      }
    }
  }
}
